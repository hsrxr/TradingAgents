# TradingAgents 环境变量配置示例
# 复制此文件为 .env 并填入实际的值
# 注意：.env 文件不会上传到 Git 仓库（已在 .gitignore 中配置）

# ============================================
# LLM 配置
# ============================================

# OpenAI API 密钥（用于 DeepSeek 兼容端点）
OPENAI_API_KEY=your_openai_api_key_here

# LLM 模型配置
# 用于深度推理的模型
LLM_MODEL_DEEP=deepseek-reasoner

# 用于快速响应的模型
LLM_MODEL_QUICK=deepseek-chat

# OpenAI 兼容的 API 基础 URL（DeepSeek）
OPENAI_API_BASE=https://api.deepseek.com

# ============================================
# 数据源 API（可选，如需用到）
# ============================================

# GeckoTerminal API（加密货币价格数据）
# 无需密钥，但可能有速率限制
COINGECKO_API_KEY=optional

# CoinMarketCap API
COINMARKETCAP_API_KEY=your_key_if_used

# AlphaVantage API（股票数据）
ALPHAVANTAGE_API_KEY=your_key_if_used

# # LunarCrush API（加密货币社交信号）
# LUNARCRUSH_API_KEY=your_key_if_used

# ============================================
# 数据库和存储配置
# ============================================

# SQLite 数据库路径（默认在 trade_memory/）
DATABASE_PATH=./trade_memory/portfolio.db

# ChromaDB 存储路径（向量数据库）
CHROMADB_DATA_PATH=./trade_memory/chroma_data

# ============================================
# 日志配置
# ============================================

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE_PATH=./logs/trading_agent.log

# ============================================
# 交易配置
# ============================================

# 默认交易对（示例：WETH/USDC）
DEFAULT_PAIR=WETH/USDC

# 交易时间间隔（秒）
TRADING_INTERVAL=3600

# 最大头寸规模（百分比，0.0 - 1.0）
MAX_POSITION_SIZE=0.1

# Kelly 公式系数（调整风险敞口，建议 0.1-0.5）
KELLY_FRACTION=0.25

# ============================================
# 分析器配置
# ============================================

# 启用哪些分析器（逗号分隔）
ENABLED_ANALYSTS=market,news,quant

# 技术指标周期（分钟）
INDICATOR_PERIOD=60

# ============================================
# 开发和测试环境
# ============================================

# 开发模式（True/False）
DEBUG_MODE=False

# 测试模式（True/False，若启用则使用模拟数据）
TEST_MODE=False

# ============================================
# 监控和告警
# ============================================

# Slack Webhook URL（用于告警通知）
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# 邮件配置（用于告警）
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_FROM=your_email@example.com
# EMAIL_TO=recipient@example.com
# EMAIL_PASSWORD=your_app_password

# ============================================
# 其他配置
# ============================================

# 时区设置
TIMEZONE=UTC

# 代理设置（如需要通过代理访问外部 API）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# ============================================
# 注意事项
# ============================================
# 1. 不要在此文件中提交真实的 API 密钥
# 2. .env 文件已被 .gitignore 忽略，不会上传到 Git
# 3. 本地开发时，复制此文件为 .env 并填入你的实际值
# 4. 团队成员需各自创建自己的 .env 文件
# 5. 敏感信息（API 密钥等）仅保存在本地 .env 文件中
